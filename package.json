{
  "name": "plyflow-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": { "node": ">=24" },
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test && vitest run --config vitest.examples.config.ts",
    "test:watch": "vitest",
    "lint": "pnpm -r lint",
    "dev": "tsx --conditions=@plyflow/source packages/cli/src/index.ts",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm -r build && changeset publish"
  },
  "devDependencies": {
    "@plyflow/core": "workspace:*",
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.1",
    "eslint": "^10.6.0",
    "tsdown": "^0.22.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9",
    "zod": "^4.4.3"
  }
}
